# ═══════════════════════════════════════════════════════════════
class DailySummaryService(QObject):
    summary_ready = pyqtSignal(str)

    def __init__(self, user):
        super().__init__()
        self.user = user
        self.timer = QTimer()
        self.timer.timeout.connect(self._check_summary)
        self.timer.start(60000)  # Her dakika kontrol
        self.last_summary_date = ""

    def _check_summary(self):
        settings = get_settings()
        hour = settings.get("daily_summary_hour", 9)
        now = datetime.now()
        today = now.strftime("%d.%m.%Y")
        if now.hour == hour and today != self.last_summary_date:
            self.last_summary_date = today
            self._generate_summary()

    def _generate_summary(self):
        settings = get_settings()
        api_key = settings.get("openai_api_key", "")
        if not api_key:
            return
        ctx = get_daily_context(self.user)
        messages = [
            {"role": "system", "content": ctx},
            {"role": "user", "content": f"Bugün {datetime.now().strftime('%d.%m.%Y %H:%M')} için günlük atölye özetini hazırla. Kısa tut, önemli uyarıları öne çıkar."}
        ]
        self.worker = AIWorker(api_key, messages)
        self.worker.response_ready.connect(lambda t: self.summary_ready.emit(t))
        self.worker.start()

        # Kaydet
        all_s = load_json(DAILY_SUMMARY_FILE, {})
        all_s[self.user] = all_s.get(self.user, [])
        all_s[self.user].append({
            "tarih": datetime.now().strftime("%d.%m.%Y"),
            "saat": datetime.now().strftime("%H:%M"),
            "durum": "oluşturuldu"
        })
        save_json(DAILY_SUMMARY_FILE, all_s)


