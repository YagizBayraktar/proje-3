#  TTS WORKER
# ═══════════════════════════════════════════════════════════════
class TTSWorker(QThread):
    def __init__(self, text, engine="gtts"):
        super().__init__()
        self.text = text
        self.engine = engine

    def run(self):
        try:
            if self.engine == "gtts" and GTTS_OK:
                tts = gTTS(text=self.text, lang="tr", slow=False)
                tmp = tempfile.NamedTemporaryFile(delete=False, suffix=".mp3")
                tts.save(tmp.name)
                if sys.platform == "win32":
                    os.startfile(tmp.name)
                elif sys.platform == "darwin":
                    subprocess.run(["afplay", tmp.name])
                else:
                    subprocess.run(["mpg321", tmp.name], capture_output=True)
                time.sleep(1)
                os.unlink(tmp.name)
            elif TTS_OK:
                engine = pyttsx3.init()
                engine.say(self.text)
                engine.runAndWait()
        except Exception:
            pass


