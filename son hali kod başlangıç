        except ValueError:
            self.gen_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.gen_info.setText("✗ Geçerli sayı gir.")

    def _change_password(self):
        old=self.pw_old.text().strip(); new=self.pw_new.text().strip(); new2=self.pw_new2.text().strip()
        if not old or not new or len(new)<4 or new!=new2:
            self.pw_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.pw_info.setText("✗ Kontrol edin."); return
        users=load_users(); changed=False
        for u in users:
            if u["username"]==self.user and u.get("password_hash")==hash_password(old):
                u["password_hash"]=hash_password(new); changed=True; break
        if not changed:
            self.pw_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.pw_info.setText("✗ Şifre yanlış."); return
        save_users(users)
        self.pw_info.setStyleSheet(f"color: {SM.t('success')}; border: none;"); self.pw_info.setText("✓ Güncellendi.")
        for e in [self.pw_old,self.pw_new,self.pw_new2]: e.clear()

