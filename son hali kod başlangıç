    def _bulk_add(self):
        dlg = QDialog(self); dlg.setWindowTitle("Toplu Stok Ekle"); dlg.setMinimumSize(500,400)
        dlg.setStyleSheet(f"background: {SM.t('bg')}; color: {SM.t('text')};")
