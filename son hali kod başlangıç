    def _append_message(self, sender, text, color=None):
        cursor = self.chat_display.textCursor()
        cursor.movePosition(cursor.MoveOperation.End)
        self.chat_display.setTextCursor(cursor)

        if sender == "🤖":
            bg = SM.t("input_bg")
            tc = SM.t("accent")
            align = "left"
        else:
            bg = SM.t("accent2")
            tc = "white"
            align = "right"

        time_str = datetime.now().strftime("%H:%M")
        html = f"""
        <div style="text-align:{align}; margin:6px 0;">
            <span style="font-size:11px; color:{SM.t('text_dim')};">{sender} {time_str}</span><br>
            <span style="background:{bg}; color:{tc}; border-radius:10px;
                         padding:6px 10px; display:inline-block; max-width:280px;
                         font-size:12px; white-space:pre-wrap;">{text}</span>
        </div>
        """
        self.chat_display.insertHtml(html)
        self.chat_display.ensureCursorVisible()

    def _send_message(self):
        text = self.input_field.text().strip()
        if not text:
            return
        self.input_field.clear()
        self._append_message("👤", text)

        settings = get_settings()
        api_key = settings.get("openai_api_key", "")
        if not api_key:
            self._append_message("🤖", "⚠️ API anahtarı yok!\nAyarlar → AI Asistan sekmesine gidip OpenAI API key'ini gir.")
            return

        # Sistem mesajı
        ctx = get_daily_context(self.user)
        messages = [{"role": "system", "content": ctx}]
        # Geçmiş ekle
        for h in self.chat_history[-10:]:
            messages.append(h)
        messages.append({"role": "user", "content": text})
        self.chat_history.append({"role": "user", "content": text})

        self.typing_lbl.setText("⏳ AI düşünüyor...")
        self.status_dot.setStyleSheet("color: #FFD600; border: none; background: transparent; font-size: 10px;")

        self.ai_worker = AIWorker(api_key, messages, "gpt-4o")
        self.ai_worker.response_ready.connect(self._on_ai_response)
        self.ai_worker.error_occurred.connect(self._on_ai_error)
        self.ai_worker.start()

    def _on_ai_response(self, text):
        self.typing_lbl.setText("")
        self.status_dot.setStyleSheet("color: #00FF88; border: none; background: transparent; font-size: 10px;")
        self._append_message("🤖", text)
        self.chat_history.append({"role": "assistant", "content": text})
        self._save_history()

        if self.voice_toggle.isChecked():
            self._speak(text[:300])  # İlk 300 karakter

    def _on_ai_error(self, err):
        self.typing_lbl.setText("")
        self.status_dot.setStyleSheet("color: #FF1744; border: none; background: transparent; font-size: 10px;")
        self._append_message("🤖", f"❌ Hata: {err}")

    def _quick_question(self, question):
        q_map = {
            "📊 Günlük Özet": "Bugünkü atölye durumunu özetle. Önemli uyarılar var mı?",
            "💰 Kar/Zarar": "Toplam kar/zarar durumumu analiz et ve iyileştirme önerisi ver.",
            "📦 Düşük Stok": "Düşük stokları listele ve ne zaman sipariş vermem gerektiğini söyle.",
            "👥 En İyi Müşteri": "En değerli müşterilerimi analiz et ve ilişki önerileri ver.",
            "📈 Tavsiye": "Atölyemi büyütmek için 3 somut tavsiye ver.",
            "🔧 Bakım Gerekli mi?": "Yazıcı bakım durumumu değerlendir.",
        }
        self.input_field.setText(q_map.get(question, question))
        self._send_message()

    def _daily_summary(self):
        self.input_field.setText("Bugünün tam özetini ver: satışlar, kar, uyarılar, öneriler. Madde madde yaz.")
        self._send_message()

    def _start_voice(self):
        if not SR_OK:
            self._append_message("🤖", "❌ SpeechRecognition kurulu değil.\npip install SpeechRecognition pyaudio")
            return
        self.mic_btn.setText("🔴")
        self.mic_btn.setStyleSheet("""
            QPushButton {
                background: #FF0000; color: white;
                border: none; border-radius: 20px; font-size: 16px;
                animation: pulse 1s infinite;
            }
        """)
        self.typing_lbl.setText("🎤 Dinleniyor... (Türkçe / İngilizce)")

        self.voice_worker = VoiceWorker()
        self.voice_worker.text_ready.connect(self._on_voice_text)
        self.voice_worker.error_occurred.connect(self._on_voice_error)
        self.voice_worker.listening_started.connect(lambda: self.typing_lbl.setText("🎙️ Konuşun..."))
        self.voice_worker.start()

    def _on_voice_text(self, text):
        self.mic_btn.setText("🎤")
        self.mic_btn.setStyleSheet(f"""
            QPushButton {{
                background: {SM.t('danger')}; color: white;
                border: none; border-radius: 20px; font-size: 16px;
            }}
        """)
        self.typing_lbl.setText(f"✅ Anlaşıldı: {text}")
        self.input_field.setText(text)
        self._send_message()

    def _on_voice_error(self, err):
        self.mic_btn.setText("🎤")
        self.typing_lbl.setText(f"❌ {err}")

    def _speak(self, text):
        settings = get_settings()
        engine = settings.get("tts_engine", "gtts")
        self.tts_worker = TTSWorker(text, engine)
        self.tts_worker.start()

    def _clear_chat(self):
        self.chat_display.clear()
        self.chat_history = []
        self._save_history()
        self._append_message("🤖", "Konuşma geçmişi temizlendi. Nasıl yardımcı olabilirim?")


