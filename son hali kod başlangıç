    def _test_api(self):
        api_key=self.e_api_key.text().strip()
        if not api_key:
            self.ai_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.ai_info.setText("✗ API key boş."); return
        if not OPENAI_OK:
            self.ai_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.ai_info.setText("✗ openai kütüphanesi kurulu değil."); return
        self.ai_info.setText("⏳ Test ediliyor...")
        def run_test():
            try:
                client=OpenAI(api_key=api_key)
                resp=client.chat.completions.create(model="gpt-4o",messages=[{"role":"user","content":"Merhaba, bağlantı testi."}],max_tokens=20)
                txt=resp.choices[0].message.content
                self.ai_info.setStyleSheet(f"color: {SM.t('success')}; border: none;"); self.ai_info.setText(f"✓ Bağlantı başarılı! GPT: {txt[:50]}")
            except Exception as ex:
                self.ai_info.setStyleSheet(f"color: {SM.t('danger')}; border: none;"); self.ai_info.setText(f"✗ Hata: {str(ex)[:100]}")
        t=threading.Thread(target=run_test,daemon=True); t.start()

