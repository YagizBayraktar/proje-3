    def _calc_sale(self):
        try:
            price=float(self.e_price.text().replace(",",".") or "0")
            qty=int(self.e_qty.text() or "1")
            disc=float(self.e_disc.text().replace(",",".") or "0")
            kargo=float(self.e_kargo.text().replace(",",".") or "0")
            kdv_r=get_settings().get("kdv_rate",20) if self.chk_kdv.isChecked() else 0
            subtotal=price*qty; indirim=subtotal*(disc/100); total=subtotal-indirim+kargo
            kdv_amount=total*(kdv_r/100); genel=total+kdv_amount
            self.lbl_calc.setText(
                f"Ara Toplam: {subtotal:.2f} TL  |  İndirim: {indirim:.2f} TL\n"
                f"Kargo: {kargo:.2f} TL  |  KDV ({kdv_r}%): {kdv_amount:.2f} TL\n"
                f"GENEL TOPLAM: {genel:.2f} TL"
            )
        except Exception as ex: self.lbl_calc.setText(f"Hata: {ex}")

    def _gen_qr(self):
        if not QR_OK:
            QMessageBox.warning(self,"Hata","qrcode kurulu değil.\npip install qrcode pillow"); return
        try:
            price=float(self.e_price.text().replace(",",".") or "0")
            product=self.e_product.text().strip() or "Ürün"
            qr_data=f"3D Atölye Ödeme\nÜrün: {product}\nTutar: {price:.2f} TL\nTarih: {datetime.now().strftime('%d.%m.%Y')}"
            qr=qrcode.QRCode(version=1,box_size=6,border=2)
            qr.add_data(qr_data); qr.make(fit=True)
            img=qr.make_image(fill_color="black",back_color="white")
            tmp=tempfile.NamedTemporaryFile(delete=False,suffix=".png")
            img.save(tmp.name)

            dlg=QDialog(self); dlg.setWindowTitle(f"QR Kod — {product}")
            dlg.setStyleSheet(f"background: {SM.t('bg')};")
            l=QVBoxLayout(dlg)
            lbl=QLabel(); pm=QPixmap(tmp.name); lbl.setPixmap(pm.scaled(300,300,Qt.AspectRatioMode.KeepAspectRatio))
